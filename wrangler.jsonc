{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "claimmosaic-docs",
  "compatibility_date": "2025-09-03",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "assets": {
    "directory": "./dist"
  }
}
